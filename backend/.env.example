# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── MySQL ────────────────────────────────────────────────────
DB_HOST=129.121.42.24
DB_PORT=3306
DB_NAME=trat_itr
DB_USER=trat_admin
DB_PASSWORD=your_password_here
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ── Redis (optional – caching) ───────────────────────────────
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL_SECONDS=300

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=https://itrdev.tratoagro.com.br

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
